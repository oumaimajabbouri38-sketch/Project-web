<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Page 1</title>

    <style>

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

    .background {
    height: 100vh;
    width: 100%;
    background: linear-gradient(rgba(0, 0, 0, 0.5), transparent), 
                url('https://images.pexels.com/photos/13896557/pexels-photo-13896557.jpeg'); 
    background-size: cover;
    background-position: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: white;
    text-align: center;
    position: relative;
}

.logo {
    position: absolute;
    top: 20px;
    left: 30px;
    
}

#text {
    border: 2px solid #bff10a; 
    padding: 20px 40px;
    margin-bottom: 20px;
    display: inline-block;
}

h2 {
    font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;
    font-size: 3rem;
    font-style: italic;
    text-transform: uppercase;
    line-height: 1.3;
}

.highlight {
    color: #f1f114; 
}

.btn {
    display: inline-block;
    background-color: #f1f114;
    color: black;
    padding: 15px 40px;
    text-decoration: none;
    font-weight: bold;
    font-size: 1.2rem;
    transition: 0.3s;
}

.btn:hover {
    background-color: white;
    transform: scale(1.05);
}

@media (max-width:768px) {
    h2 {
        font-size: 1.5rem;
    }

    .text {
        padding: 10px 20px;
    }
}
  </style>
</head>
<body>

    <section class="background">
        <div class="logo">
            <img src="FIt_with_you-removebg-preview (1).png" width="200px">
        </div>

        <br>

        <div class="content">
            <div class="text">
                <h2>
“You don’t need <span class="highlight">motivation</span>. 
You need <span class="highlight">discipline</span>. 
<span class="highlight">Motivation</span> comes and goes, but <span class="highlight">discipline</span> is what gets you out of bed.”
                </h2>
            </div>
            
            <a href="page2.html" class="btn" target="_blank">START NOW</a>
        </div>
    </section>

<script>
const projectName = "FIT WITH YOU";
let userName = "Guest";
let visitCount = 0;

document.addEventListener("DOMContentLoaded", function () {

    console.log("Project:", projectName);

    alert("Welcome to " + projectName);

    let askName = prompt("What's your name?");
    if (askName) {
        userName = askName;
    }

    alert("Hello " + userName);

    let title = document.querySelector("h2");
    let button = document.querySelector(".btn");

    if (title) {
        title.innerText += " - Stay Strong!";
    }

    if (button) {
        button.addEventListener("click", function () {
            visitCount++;
            alert("Start training " + userName);
            console.log("Button clicked " + visitCount + " times");
        });
    }

    if (visitCount === 0) {
        console.log("User didn't start yet");
    } else {
        console.log("User started training");
    }

    for (let i = 1; i <= 3; i++) {
        console.log("Workout set " + i);
    }

    let exercises = ["Push ups", "Squats", "Plank"];

    exercises.forEach(function (item) {
        console.log("Exercise:", item);
    });

    function sayWelcome(name) {
        return "Welcome " + name + " to fitness world";
    }

    console.log(sayWelcome(userName));

    let calcCalories = function (minutes) {
        return minutes * 8;
    };

    console.log("Calories burned:", calcCalories(30));

    let newElement = document.createElement("p");
    newElement.innerText = "Keep going, don't stop!";
    document.body.appendChild(newElement);

});
</script>

</body>
</html>